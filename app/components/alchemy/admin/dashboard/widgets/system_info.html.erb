<div class="widget system-info">
  <div class="logo">
    <%= logo %>
  </div>
  <div class="version-info">
    <span class="version">
      <%= @alchemy_version %>
    </span>

    <%= render Alchemy::Admin::UpdateCheck.new %>

    <span class="ruby-rails-version">
