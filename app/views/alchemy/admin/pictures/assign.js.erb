(function () {
  const formField = document.getElementById("<%= @form_field_id -%>")
  formField.value = "<%= @assignable_id %>"
  formField.setAttribute("data-image-file-width", "<%= @picture.image_file_width %>")
  formField.setAttribute("data-image-file-height", "<%= @picture.image_file_height %>")
  Alchemy.closeCurrentDialog(function () {
    const elementEditor = formField.closest("alchemy-element-editor")
    if (elementEditor) {
      elementEditor.setDirty()
    }
  })
})()
