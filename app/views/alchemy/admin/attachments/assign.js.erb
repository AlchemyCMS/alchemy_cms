(function () {
  const formField = document.getElementById("<%= @form_field_id -%>")
  document
    .querySelectorAll("#assignable_<%= @assignable_id %> a")
    .forEach((link) => {
      link.setAttribute("href", "#")
      link.onclick = () => false
    })
  formField.value = "<%= @assignable_id %>"
  const parent = formField.parentElement
  parent.querySelector(":scope > .file_name").textContent = "<%= @attachment.name %>"
  parent.querySelector(":scope > .file_icon").innerHTML = "<%= j render_icon(@attachment.icon_css_class) %>"
  parent.querySelector(":scope > .remove_file_link").classList.remove("hidden")
  Alchemy.closeCurrentDialog(() => {
    const elementEditor = formField.closest("alchemy-element-editor")
    if (elementEditor) {
      elementEditor.setDirty(formField)
    }
  })
})()
